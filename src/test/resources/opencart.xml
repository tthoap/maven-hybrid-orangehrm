<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd" >

<suite name="OpenCart - UI automation Testing" verbose="1" >
    <parameter name="userUrl" value="http://localhost:90/opencart"></parameter>
    <parameter name="adminUrl" value="http://localhost:90/opencart/admin"></parameter>

    <test name="Run on Firefox browser" >
        <parameter name="browser" value="Firefox"></parameter>
        <classes>
            <class name="com.opencart.Level_09_Switch_Url_Role" />
        </classes>
    </test>
</suite>