<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd" >

<suite name="TechPanda - UI automation Testing" verbose="1" >
    <listeners>
        <listener class-name="core.MethodListener"></listener>
        <listener class-name="reportConfig.AllureTestListener"></listener>
    </listeners>
    
    <parameter name="appUrl" value="http://live.techpanda.org/"></parameter>
    
    <test name="Run on Edge browser" preserve-order="true" >
        <parameter name="browser" value="edge"></parameter>
        <classes>
            <class name="com.techpanda.share.Register" />
            <class name="com.techpanda.Level_20_Cookies" />
        </classes>
    </test>


</suite>